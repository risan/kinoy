{
  "name": "@jbandassociates/jbw-ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/jbw-ui.cjs",
  "module": "./dist/jbw-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/jbw-ui.js",
      "require": "./dist/jbw-ui.cjs"
    },
    "./theme": "./dist/theme/default.css",
    "./theme/datepicker": "./dist/theme/datepicker.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbandassociates/jbw-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite --config dev/vite.config.ts",
    "build": "run-p type-check build-only",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "bun run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vee-validate": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vuepic/vue-datepicker": {
      "optional": true
    },
    "@googlemaps/js-api-loader": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "es-toolkit": "^1.45.0",
    "fuse.js": "^7.1.0",
    "imask": "^7.6.1",
    "vue-currency-input": "^3.2.2"
  },
  "devDependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/vue3-vite": "^10.2.14",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "@vuepic/vue-datepicker": "^12.1.0",
    "ajv": "^8.18.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-storybook": "10.2.14",
    "eslint-plugin-vue": "~10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "~1.51.0",
    "storybook": "^10.2.14",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vee-validate": "^4.15.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5",
    "yup": "^1.7.1"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx}": [
      "oxfmt",
      "oxlint --fix",
      "eslint --fix --cache"
    ],
    "*.css": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
